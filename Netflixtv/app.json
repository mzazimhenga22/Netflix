{
  "expo": {
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@react-native-tvos/config-tv",
        {
          "androidTVBanner": "./assets/logo.png",
          "appleTVImages": {
            "icon": "./assets/logo.png",
            "iconSmall": "./assets/logo.png",
            "iconSmall2x": "./assets/logo.png",
            "topShelf": "./assets/logo.png",
            "topShelf2x": "./assets/logo.png",
            "topShelfWide": "./assets/logo.png",
            "topShelfWide2x": "./assets/logo.png"
          }
        }
      ]
    ],
    "icon": "./assets/logo.png",
    "android": {
      "package": "com.com1",
      "edgeToEdgeEnabled": true
    },
    "ios": {
      "bundleIdentifier": "com.movieflix.tv"
    },
    "newArchEnabled": true,
    "name": "Netflixtv",
    "slug": "Netflixtv",
    "orientation": "landscape",
    "userInterfaceStyle": "automatic",
    "extra": {
      "eas": {
        "projectId": "e36af8cd-71ba-4856-958d-8d87c59f5d51"
      }
    }
  }
}
