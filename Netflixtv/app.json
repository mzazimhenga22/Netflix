{
  "expo": {
    "scheme": "netflixtv",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/images/netflix-n-logo.png",
          "imageResizeMode": "contain",
          "dark": {
            "backgroundColor": "#000000",
            "image": "./assets/images/netflix-n-logo.png",
            "imageResizeMode": "contain"
          }
        }
      ],
      [
        "@react-native-tvos/config-tv",
        {
          "androidTVBanner": "./assets/logo.png",
          "appleTVImages": {
            "icon": "./assets/logo.png",
            "iconSmall": "./assets/logo.png",
            "iconSmall2x": "./assets/logo.png",
            "topShelf": "./assets/logo.png",
            "topShelf2x": "./assets/logo.png",
            "topShelfWide": "./assets/logo.png",
            "topShelfWide2x": "./assets/logo.png"
          }
        }
      ]
    ],
    "icon": "./assets/logo.png",
    "android": {
      "package": "com.movieflix.tv",
      "edgeToEdgeEnabled": true
    },
    "ios": {
      "bundleIdentifier": "com.movieflix.tv"
    },
    "newArchEnabled": true,
    "name": "Netflixtv",
    "slug": "Netflixtv",
    "version": "1.0.9",
    "orientation": "landscape",
    "userInterfaceStyle": "automatic",
    "extra": {
      "eas": {
        "projectId": "654c284d-c4df-4398-acbd-f7e59d692e0d"
      }
    },
    "owner": "derrogpt"
  }
}
